                            },
                            {
                              "value": "วัยทำงาน 25-35",
                              "label": "วัยทำงาน 25-35"
                            },
                            {
                              "value": "กลางคน 35-50",
                              "label": "กลางคน 35-50"
                            },
                            {
                              "value": "สูงวัย 50+",
