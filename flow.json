{
  "schemaVersion": 1,
  "title": "หมีทำแทน Flow",
  "icon": "pets",
  "app": { "id": "flow", "name": "flow" },
  "persistBar": true,
  "devBar": false,
  "chrome": { "content": { "className": "!max-w-none !p-0" } },
  "run": { "maxParallel": 1, "staggerMs": 0, "maxAttempts": 3, "retryDelayMs": 15000, "batchDelayMs": 15000 },
  "theme": { "vars": { "--ev-accent": "#f97316", "--ev-bg": "#050505", "--ev-surface": "rgba(255,255,255,0.03)", "--ev-surface2": "rgba(255,255,255,0.08)", "--ev-border": "rgba(255,255,255,0.08)" } },
  "home": {
    "title": "หมีทำแทน Flow", "subtitle": "ออกแบบงาน gen ภาพ/วิดีโอบน Flow Labs → รันเป็นชุดอัตโนมัติ",
    "tag": "easybear flow", "hero": "🐻", "cta": "สร้างโปรเจกต์ใหม่"
  },
  "editor": { "sourceColl": "shots", "map": { "image": "startFrame", "motion": "motion", "duration": "duration" }, "defaultAspect": "9:16" },
  "settings": {
    "title": "ตั้งค่าการผลิต", "fullPage": true,
    "form": [
      { "el": "stepper", "field": "maxParallelUi", "label": "จำนวนงานพร้อมกัน", "min": 1, "max": 8 },
      { "el": "stepper", "field": "staggerUi", "label": "พักระหว่างงาน (วิ)", "min": 0, "max": 30 },
      { "el": "stepper", "field": "batchUi", "label": "พักระหว่างรอบ (วิ)", "min": 0, "max": 60 },
      { "el": "stepper", "field": "phaseUi", "label": "พักระหว่างขั้นตอน (วิ)", "min": 0, "max": 120 }
    ]
  },
  "lookups": {
    "imageModels": { "🍌 Nano Banana Pro": "🍌 Nano Banana Pro", "🍌 Nano Banana 2": "🍌 Nano Banana 2", "Imagen 4": "Imagen 4" },
    "videoModels": { "Omni Flash": "Omni Flash", "Veo 3.1 - Lite": "Veo 3.1 - Lite", "Veo 3.1 - Fast": "Veo 3.1 - Fast", "Veo 3.1 - Quality": "Veo 3.1 - Quality" }
  },
  "values": { "genMode": "video", "imageModel": "🍌 Nano Banana Pro", "videoModel": "Veo 3.1 - Fast", "aspect": "9:16", "viewMode": "visual" },
  "collections": {
    "uploads": { "fields": ["name"], "slots": ["media"] },
    "assets": { "fields": ["prompt"], "slots": ["image"] },
    "shots": { "fields": ["title", "startPrompt", "endPrompt", "videoPrompt", "hasStart", "hasEnd", "duration"], "slots": ["startFrame", "endFrame", "motion"] },
    "images": { "fields": ["prompt"], "slots": ["image"] }
  },
  "seed": {},
  "ops": [
    { "id": "genAsset", "type": "image", "over": "assets", "out": "image", "model": "{values.imageModel}", "aspectRatio": "{values.aspect}", "prompt": "{item.prompt}",
      "refs": { "op": "lookupRefs", "from": "uploads", "by": "{item.refs.up}", "slot": "media", "also": [ { "from": "assets", "by": "{item.refs.asset}", "slot": "image" } ] } },
    { "id": "genStart", "type": "image", "over": "shots", "out": "startFrame", "where": "hasStart=true", "model": "{values.imageModel}", "aspectRatio": "{values.aspect}", "prompt": "{item.startPrompt}",
      "refs": { "op": "lookupRefs", "from": "uploads", "by": "{item.refs.startUp}", "slot": "media", "also": [ { "from": "assets", "by": "{item.refs.startAsset}", "slot": "image" }, { "from": "shots", "by": "{item.refs.startFromEnd}", "slot": "endFrame" }, { "from": "shots", "by": "{item.refs.startFromStart}", "slot": "startFrame" } ] } },
    { "id": "genEnd", "type": "image", "over": "shots", "out": "endFrame", "where": "hasEnd=true", "model": "{values.imageModel}", "aspectRatio": "{values.aspect}", "prompt": "{item.endPrompt}",
      "refs": { "op": "lookupRefs", "from": "assets", "by": "{item.refs.endAsset}", "slot": "image", "also": [ { "from": "shots", "by": "{item.refs.endFromEnd}", "slot": "endFrame" } ] } },
    { "id": "genMotion", "type": "video", "over": "shots", "out": "motion", "model": "{values.videoModel}", "aspectRatio": "{values.aspect}", "durationSeconds": "{item.duration}", "prompt": "{item.videoPrompt}",
      "startFrame": "{item.slots.startFrame}", "endFrame": "{item.slots.endFrame}", "refs": { "op": "lookupRefs", "from": "shots", "by": "{item.refs.motionFromEnd}", "slot": "endFrame" } },
    { "id": "genImage", "type": "image", "over": "images", "out": "image", "model": "{values.imageModel}", "aspectRatio": "{values.aspect}", "prompt": "{item.prompt}",
      "refs": { "op": "lookupRefs", "from": "uploads", "by": "{item.refs.up}", "slot": "media", "also": [ { "from": "assets", "by": "{item.refs.asset}", "slot": "image" } ] } }
  ],
  "stages": [ { "op": "genAsset" }, { "checkpoint": "build" } ],
  "phases": [
    {
      "id": "build", "title": "ออกแบบงาน", "hideTitle": true, "navLabel": "ออกแบบ",
      "form": [
        { "el": "split", "sidebarWidth": 300, "mainClass": "p-8 min-h-[calc(100vh-56px)]",
          "style": { "background": "rgba(255,255,255,0.015)", "borderRight": "1px solid rgba(255,255,255,0.07)", "padding": "18px 16px", "maxHeight": "none", "top": "0", "minHeight": "calc(100vh - 56px)" },
          "sidebar": [
            { "el": "box", "className": "border border-white/10 rounded-2xl p-3.5 flex flex-col gap-3.5", "card": [
              { "el": "row", "style": { "justifyContent": "space-between", "alignItems": "flex-start" }, "card": [
                { "el": "box", "style": { "flex": "1" }, "card": [
                  { "el": "text", "value": "Video Pipeline", "className": "text-[13px] font-black leading-none", "when": "genMode=video" },
                  { "el": "text", "value": "Image Pipeline", "className": "text-[13px] font-black leading-none", "when": "genMode=image" },
                  { "el": "text", "value": { "op": "concat", "parts": [ { "op": "count", "from": "assets" }, " assets · ", { "op": "count", "from": "images" }, " images · ", { "op": "count", "from": "shots" }, " videos" ] }, "className": "text-[9px] text-white/40 mt-1" }
                ] },
                { "el": "text", "value": { "op": "concat", "parts": [ { "op": "count", "from": "shots" }, " tasks" ] }, "className": "text-[9px] text-white/40" }
              ] },
              { "el": "row", "style": { "alignItems": "center", "gap": "4px" }, "card": [
                { "el": "box", "className": "flex flex-col items-center gap-1.5 flex-1", "card": [
                  { "el": "box", "className": "w-11 h-11 rounded-xl border border-white/10 flex items-center justify-center bg-white/[0.03]", "card": [ { "el": "icon", "value": "inventory_2", "className": "text-white/50" } ] },
                  { "el": "text", "value": "ASSETS", "className": "text-[8px] font-bold uppercase tracking-[1.5px] text-white/35" },
                  { "el": "text", "value": { "op": "count", "from": "assets" }, "className": "text-[13px] font-black" }
                ] },
                { "el": "box", "className": "h-px w-4 bg-white/12 self-start mt-[17px] shrink-0" },
                { "el": "box", "className": "flex flex-col items-center gap-1.5 flex-1", "card": [
                  { "el": "box", "className": "w-11 h-11 rounded-xl border border-white/10 flex items-center justify-center bg-white/[0.03]", "card": [ { "el": "icon", "value": "image", "className": "text-white/50" } ] },
                  { "el": "text", "value": "IMAGE", "className": "text-[8px] font-bold uppercase tracking-[1.5px] text-white/35" },
                  { "el": "text", "value": { "op": "count", "from": "shots", "slot": "startFrame" }, "className": "text-[13px] font-black" }
                ] },
                { "el": "box", "className": "h-px w-4 bg-white/12 self-start mt-[17px] shrink-0" },
                { "el": "box", "className": "flex flex-col items-center gap-1.5 flex-1", "card": [
                  { "el": "box", "className": "w-11 h-11 rounded-xl border border-white/10 flex items-center justify-center bg-white/[0.03]", "card": [ { "el": "icon", "value": "movie", "className": "text-white/50" } ] },
                  { "el": "text", "value": "VIDEO", "className": "text-[8px] font-bold uppercase tracking-[1.5px] text-white/35" },
                  { "el": "text", "value": { "op": "count", "from": "shots", "slot": "motion" }, "className": "text-[13px] font-black" }
                ] }
              ] }
            ] },
            { "el": "text", "value": "OUTPUT CONFIG", "className": "text-[9px] font-black uppercase tracking-[2px] text-white/35 mt-2" },
            { "el": "segmented", "field": "genMode", "variant": "tab", "options": [ { "value": "video", "label": "VIDEO", "icon": "videocam" }, { "value": "image", "label": "IMAGE", "icon": "image" } ] },
            { "el": "segmented", "field": "aspect", "variant": "tab", "options": [ { "value": "9:16", "label": "9:16" }, { "value": "16:9", "label": "16:9" } ] },
            { "el": "dropdown", "field": "imageModel", "label": "IMAGE MODEL", "variant": "pill", "options": { "table": "imageModels" } },
            { "el": "dropdown", "field": "videoModel", "label": "VIDEO MODEL", "variant": "pill", "options": { "table": "videoModels" }, "when": "genMode=video" },
            { "el": "gen-phase", "label": "เริ่มรันงาน", "ops": ["genAsset"], "chain": ["genStart", "genEnd", "genMotion"], "variant": "solid", "icon": "play_arrow", "when": "genMode=video" },
            { "el": "gen-phase", "label": "เริ่มรันงาน", "ops": ["genAsset", "genImage"], "variant": "solid", "icon": "play_arrow", "when": "genMode=image" },
            { "el": "text", "value": "ACTIVITY STREAM", "className": "text-[9px] font-black uppercase tracking-[2px] text-white/35 mt-2" },
            { "el": "custom", "fn": "flowLog" },
            { "el": "divider" },
            { "el": "row", "style": { "justifyContent": "space-between", "alignItems": "center" }, "card": [
              { "el": "text", "value": "● READY", "className": "text-[9px] font-bold uppercase tracking-widest text-green-400/70" },
              { "el": "text", "value": "flow v0.2", "className": "text-[9px] text-white/25" }
            ] }
          ],
          "main": [
            { "el": "row", "style": { "justifyContent": "space-between", "alignItems": "center", "borderBottom": "1px solid rgba(255,255,255,0.06)", "paddingBottom": "14px" }, "card": [
              { "el": "text", "value": "VISUAL JOB DESIGNER", "className": "text-[11px] font-black uppercase tracking-[3px] text-white/40" },
              { "el": "row", "style": { "gap": "8px" }, "card": [
                { "el": "load-button", "label": "Import", "icon": "upload_file", "variant": "outline" },
                { "el": "segmented", "field": "viewMode", "variant": "tab", "options": [ { "value": "visual", "label": "Visual", "icon": "visibility" }, { "value": "json", "label": "JSON", "icon": "data_object" } ] }
              ] }
            ] },
            { "el": "box", "when": "viewMode=json", "className": "max-w-[860px] mx-auto w-full mt-6", "card": [ { "el": "custom", "fn": "flowJson" } ] },
            { "el": "box", "when": "viewMode=visual", "className": "max-w-[880px] mx-auto w-full flex flex-col gap-11 pt-8 pb-20", "card": [
              { "el": "row", "style": { "justifyContent": "space-between", "alignItems": "center", "borderBottom": "1px solid rgba(255,255,255,0.06)", "paddingBottom": "10px" }, "card": [
                { "el": "text", "value": "UPLOADS", "className": "text-[13px] font-black uppercase tracking-[3px] text-white/30" },
                { "el": "add-button", "coll": "uploads", "icon": "add", "variant": "ghost", "iconOnly": true }
              ] },
              { "el": "repeat", "coll": "uploads", "empty": "NO INPUTS DEFINED", "card": [
                { "el": "box", "className": "border border-white/[0.07] rounded-[24px] p-6 bg-white/[0.015] flex flex-col gap-5", "card": [
                  { "el": "row", "style": { "alignItems": "center", "justifyContent": "space-between" }, "card": [
                    { "el": "row", "style": { "alignItems": "center", "gap": "10px" }, "card": [
                      { "el": "text", "value": "ID:", "className": "text-[10px] font-bold uppercase tracking-widest text-white/30" },
                      { "el": "text", "value": "{item.id}", "className": "text-[13px] font-black px-3 py-1.5 rounded-lg bg-white/5 border border-white/8" }
                    ] },
                    { "el": "delete-button" }
                  ] },
                  { "el": "row", "style": { "alignItems": "flex-start", "gap": "24px" }, "card": [
                    { "el": "box", "style": { "width": "140px" }, "className": "flex flex-col gap-2.5 shrink-0", "card": [
                      { "el": "text", "value": "ASSET SOURCE", "className": "text-[9px] font-bold uppercase tracking-[2px] text-white/30" },
                      { "el": "media-slot", "src": "{item.slots.media}", "aspect": "1:1", "when": "item.slots.media!=" },
                      { "el": "box", "when": "item.slots.media=", "className": "flex flex-col gap-2", "card": [
                        { "el": "upload", "into": "{item.slots.media}", "label": "อัพโหลด", "accept": "image/*,video/mp4", "variant": "solid", "icon": "file_upload" },
                        { "el": "pick-button", "into": "{item.slots.media}", "filter": "image", "label": "เลือกภาพ", "variant": "outline", "icon": "photo_library" }
                      ] }
                    ] },
                    { "el": "box", "style": { "flex": "1" }, "className": "flex flex-col gap-2.5", "card": [
                      { "el": "text", "value": "STATUS INFORMATION", "className": "text-[9px] font-bold uppercase tracking-[2px] text-white/30" },
                      { "el": "box", "when": "item.slots.media!=", "className": "border border-green-500/25 bg-green-500/[0.06] rounded-2xl p-4 flex flex-col gap-3", "card": [
                        { "el": "row", "style": { "alignItems": "center", "gap": "8px" }, "card": [
                          { "el": "icon", "value": "check_circle", "className": "text-green-400 text-[20px]" },
                          { "el": "text", "value": "ASSET ACTIVE", "className": "text-green-400 font-black text-[12px] tracking-wide" }
                        ] },
                        { "el": "row", "style": { "justifyContent": "space-between", "borderTop": "1px solid rgba(255,255,255,0.06)", "paddingTop": "8px" }, "card": [
                          { "el": "text", "value": "MEDIA", "className": "text-[9px] uppercase tracking-widest text-white/30" },
                          { "el": "text", "value": "จากคลัง / อัพโหลด", "className": "text-[10px] text-white/50" }
                        ] }
                      ] },
                      { "el": "box", "when": "item.slots.media=", "className": "border border-amber-500/30 bg-amber-500/[0.06] rounded-2xl p-4 flex flex-row items-center gap-3", "card": [
                        { "el": "icon", "value": "warning", "className": "text-amber-400 text-[22px]" },
                        { "el": "box", "card": [
                          { "el": "text", "value": "ต้องอัพโหลดรูป", "className": "text-amber-300 font-bold text-[12px]" },
                          { "el": "text", "value": "Please select a media file to activate this reference.", "className": "text-amber-400/60 text-[10px]" }
                        ] }
                      ] }
                    ] }
                  ] }
                ] }
              ] },
              { "el": "row", "style": { "justifyContent": "space-between", "alignItems": "center", "borderBottom": "1px solid rgba(255,255,255,0.06)", "paddingBottom": "10px" }, "card": [
                { "el": "text", "value": "ASSETS", "className": "text-[13px] font-black uppercase tracking-[3px] text-white/30" },
                { "el": "add-button", "coll": "assets", "icon": "add", "variant": "ghost", "iconOnly": true }
              ] },
              { "el": "repeat", "coll": "assets", "empty": "NO MASTER ASSETS", "card": [
                { "el": "row", "style": { "alignItems": "flex-start" }, "card": [
                  { "el": "media-slot", "src": "{item.slots.image}", "aspect": "1:1", "style": { "maxWidth": "72px" } },
                  { "el": "box", "style": { "flex": "1" }, "card": [
                    { "el": "textarea", "field": "prompt", "placeholder": "อธิบายภาพ asset...", "maxLength": 400 },
                    { "el": "row", "card": [
                      { "el": "ref-select", "field": "up", "coll": "uploads", "label": "อ้างอิงอัพโหลด", "icon": "cloud_upload" },
                      { "el": "ai-fill-button", "field": "prompt", "prompt": "ปรับ prompt สร้างภาพให้ละเอียดสวยขึ้น (ภาษาอังกฤษ): ", "label": "แต่ง prompt", "variant": "ghost", "icon": "auto_fix_high" }
                    ] }
                  ] },
                  { "el": "gen-button", "label": "เจน", "op": "genAsset", "target": "{item}", "variant": "solid", "icon": "auto_awesome" },
                  { "el": "delete-button" }
                ] }
              ] },
              { "el": "row", "style": { "justifyContent": "space-between", "alignItems": "center", "borderBottom": "1px solid rgba(255,255,255,0.06)", "paddingBottom": "10px" }, "card": [
                { "el": "text", "value": "VIDEOS", "className": "text-[13px] font-black uppercase tracking-[3px] text-white/30", "when": "genMode=video" },
                { "el": "text", "value": "IMAGES", "className": "text-[13px] font-black uppercase tracking-[3px] text-white/30", "when": "genMode=image" },
                { "el": "add-button", "coll": "shots", "icon": "add", "variant": "ghost", "iconOnly": true, "when": "genMode=video" },
                { "el": "add-button", "coll": "images", "icon": "add", "variant": "ghost", "iconOnly": true, "when": "genMode=image" }
              ] },
              { "el": "repeat", "coll": "shots", "when": "genMode=video", "empty": "NO FINAL OUTPUTS", "card": [
                { "el": "group", "collapsible": true, "startOpen": true, "label": "{item.title}", "summary": "{item.title}", "card": [
                  { "el": "input", "field": "title", "label": "ชื่อช็อต", "style": { "fontWeight": "700" } },
                  { "el": "row", "style": { "alignItems": "flex-start" }, "card": [
                    { "el": "media-slot", "src": "{item.slots.startFrame}", "aspect": "9:16", "style": { "maxWidth": "104px" } },
                    { "el": "media-slot", "src": "{item.slots.endFrame}", "aspect": "9:16", "style": { "maxWidth": "104px" } },
                    { "el": "media-slot", "src": "{item.slots.motion}", "aspect": "9:16", "style": { "maxWidth": "104px" } }
                  ] },
                  { "el": "switch", "field": "hasStart", "label": "มีภาพเปิด (start frame)" },
                  { "el": "textarea", "field": "startPrompt", "label": "ภาพเปิด", "when": "hasStart=true", "maxLength": 400 },
                  { "el": "row", "when": "hasStart=true", "card": [
                    { "el": "ref-select", "field": "startAsset", "coll": "assets", "label": "อ้าง asset", "icon": "inventory_2" },
                    { "el": "ref-select", "field": "startFromEnd", "coll": "shots", "label": "ต่อเฟรมจบช็อตก่อน", "icon": "link", "before": true }
                  ] },
                  { "el": "switch", "field": "hasEnd", "label": "มีภาพจบ (end frame)" },
                  { "el": "textarea", "field": "endPrompt", "label": "ภาพจบ", "when": "hasEnd=true", "maxLength": 400 },
                  { "el": "note", "value": "การเคลื่อนไหว (motion)", "tone": "info", "icon": "animation" },
                  { "el": "textarea", "field": "videoPrompt", "label": "อธิบายการเคลื่อนไหว", "maxLength": 400 },
                  { "el": "segmented", "field": "duration", "label": "ความยาว", "options": [ { "value": "4", "label": "4ว" }, { "value": "6", "label": "6ว" }, { "value": "8", "label": "8ว" } ] },
                  { "el": "row", "card": [
                    { "el": "gen-button", "label": "เปิด", "op": "genStart", "target": "{item}", "variant": "outline", "icon": "image" },
                    { "el": "gen-button", "label": "จบ", "op": "genEnd", "target": "{item}", "variant": "outline", "icon": "image" },
                    { "el": "gen-button", "label": "วิดีโอ", "op": "genMotion", "target": "{item}", "variant": "solid", "icon": "movie" },
                    { "el": "download-button", "to": "{item.slots.motion}" },
                    { "el": "open-editor", "coll": "shots", "label": "ตัดต่อ", "variant": "ghost", "icon": "movie_edit" },
                    { "el": "delete-button" }
                  ] }
                ] }
              ] },
              { "el": "repeat", "coll": "images", "when": "genMode=image", "empty": "NO FINAL OUTPUTS", "card": [
                { "el": "row", "style": { "alignItems": "flex-start" }, "card": [
                  { "el": "media-slot", "src": "{item.slots.image}", "aspect": "9:16", "style": { "maxWidth": "104px" } },
                  { "el": "box", "style": { "flex": "1" }, "card": [
                    { "el": "textarea", "field": "prompt", "placeholder": "อธิบายภาพ...", "maxLength": 400 },
                    { "el": "row", "card": [
                      { "el": "ref-select", "field": "up", "coll": "uploads", "label": "อ้างอิงอัพโหลด", "icon": "cloud_upload" },
                      { "el": "ref-select", "field": "asset", "coll": "assets", "label": "อ้าง asset", "icon": "inventory_2" },
                      { "el": "ai-fill-button", "field": "prompt", "prompt": "ปรับ prompt สร้างภาพให้ละเอียดสวยขึ้น (ภาษาอังกฤษ): ", "label": "แต่ง prompt", "variant": "ghost", "icon": "auto_fix_high" }
                    ] }
                  ] },
                  { "el": "gen-button", "label": "เจน", "op": "genImage", "target": "{item}", "variant": "solid", "icon": "image" },
                  { "el": "download-button", "to": "{item.slots.image}" },
                  { "el": "delete-button" }
                ] }
              ] }
            ] }
          ]
        }
      ]
    },
    {
      "id": "monitor", "title": "คิวงาน", "subtitle": "ความคืบหน้าการผลิต", "navLabel": "คิวงาน",
      "form": [
        { "el": "dashboard", "coll": "shots", "label": "ช็อต", "when": "genMode=video" },
        { "el": "gallery", "coll": "shots", "slot": "motion", "aspect": "9:16", "when": "genMode=video", "empty": "ยังไม่มีวิดีโอที่เสร็จ" },
        { "el": "dashboard", "coll": "images", "label": "ภาพ", "when": "genMode=image" },
        { "el": "gallery", "coll": "images", "slot": "image", "aspect": "9:16", "when": "genMode=image", "empty": "ยังไม่มีภาพที่เสร็จ" }
      ]
    },
    {
