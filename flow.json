{
  "schemaVersion": 1,
  "title": "หมีทำแทน Flow",
  "icon": "pets",
  "app": { "id": "flow", "name": "flow" },
  "persistBar": true,
  "devBar": false,
  "chrome": { "content": { "className": "!max-w-none !p-0" } },
  "run": { "maxParallel": 1, "staggerMs": 0, "maxAttempts": 3, "retryDelayMs": 15000, "batchDelayMs": 15000 },
  "theme": { "vars": { "--ev-accent": "#f97316", "--ev-bg": "#050505", "--ev-surface": "rgba(255,255,255,0.03)", "--ev-surface2": "rgba(255,255,255,0.08)", "--ev-border": "rgba(255,255,255,0.08)" } },
  "home": {
    "title": "หมีทำแทน Flow", "subtitle": "ออกแบบงาน gen ภาพ/วิดีโอบน Flow Labs → รันเป็นชุดอัตโนมัติ",
    "tag": "easybear flow", "hero": "🐻", "cta": "สร้างโปรเจกต์ใหม่"
  },
  "editor": { "sourceColl": "shots", "map": { "image": "startFrame", "motion": "motion", "duration": "duration" }, "defaultAspect": "9:16" },
  "settings": {
    "title": "ตั้งค่าการผลิต", "fullPage": true,
    "form": [
      { "el": "stepper", "field": "maxParallelUi", "label": "จำนวนงานพร้อมกัน", "min": 1, "max": 8 },
      { "el": "stepper", "field": "staggerUi", "label": "พักระหว่างงาน (วิ)", "min": 0, "max": 30 },
      { "el": "stepper", "field": "batchUi", "label": "พักระหว่างรอบ (วิ)", "min": 0, "max": 60 },
      { "el": "stepper", "field": "phaseUi", "label": "พักระหว่างขั้นตอน (วิ)", "min": 0, "max": 120 }
    ]
  },
  "lookups": {
    "imageModels": { "🍌 Nano Banana Pro": "🍌 Nano Banana Pro", "🍌 Nano Banana 2": "🍌 Nano Banana 2", "Imagen 4": "Imagen 4" },
    "videoModels": { "Omni Flash": "Omni Flash", "Veo 3.1 - Lite": "Veo 3.1 - Lite", "Veo 3.1 - Fast": "Veo 3.1 - Fast", "Veo 3.1 - Quality": "Veo 3.1 - Quality" }
  },
  "values": { "genMode": "video", "imageModel": "🍌 Nano Banana Pro", "videoModel": "Veo 3.1 - Fast", "aspect": "9:16", "viewMode": "visual" },
  "collections": {
    "uploads": { "fields": ["name"], "slots": ["media"], "idPrefix": "upload" },
    "assets": { "fields": ["prompt"], "slots": ["image"], "idPrefix": "asset" },
    "shots": { "fields": ["title", "startPrompt", "endPrompt", "videoPrompt", "hasStart", "hasEnd", "duration"], "slots": ["startFrame", "endFrame", "motion"], "idPrefix": "shot" },
    "images": { "fields": ["prompt"], "slots": ["image"], "idPrefix": "img" }
  },
  "seed": {},
  "components": {
    "alertWarn": [
      { "el": "box", "className": "rounded-xl p-3.5 flex items-center gap-3 text-left border bg-amber-500/10 border-amber-500/20", "card": [
        { "el": "icon", "icon": "warning", "className": "text-amber-500 shrink-0", "textSize": "text-[20px]" },
        { "el": "box", "className": "flex flex-col gap-0.5 min-w-0", "card": [
          { "el": "text", "value": "{var.title}", "className": "!text-[12px] font-black uppercase tracking-[1.5px] !text-amber-500" },
          { "el": "text", "value": "{var.msg}", "className": "!text-[11px] font-medium !text-amber-500 opacity-60 leading-relaxed" }
        ] }
      ] }
    ]
  },
  "ops": [
    { "id": "genAsset", "type": "image", "over": "assets", "out": "image", "model": "{values.imageModel}", "aspectRatio": "{values.aspect}", "prompt": "{item.prompt}",
      "refs": { "op": "lookupRefs", "from": "uploads", "by": "{item.refs.up}", "slot": "media", "also": [ { "from": "assets", "by": "{item.refs.asset}", "slot": "image" } ] } },
    { "id": "genStart", "type": "image", "over": "shots", "out": "startFrame", "where": "hasStart=true", "model": "{values.imageModel}", "aspectRatio": "{values.aspect}", "prompt": "{item.startPrompt}",
      "refs": { "op": "lookupRefs", "from": "uploads", "by": "{item.refs.startUp}", "slot": "media", "also": [ { "from": "assets", "by": "{item.refs.startAsset}", "slot": "image" }, { "from": "shots", "by": "{item.refs.startFromEnd}", "slot": "endFrame" }, { "from": "shots", "by": "{item.refs.startFromStart}", "slot": "startFrame" } ] } },
    { "id": "genEnd", "type": "image", "over": "shots", "out": "endFrame", "where": "hasEnd=true", "model": "{values.imageModel}", "aspectRatio": "{values.aspect}", "prompt": "{item.endPrompt}",
      "refs": { "op": "lookupRefs", "from": "uploads", "by": "{item.refs.endUp}", "slot": "media", "also": [ { "from": "assets", "by": "{item.refs.endAsset}", "slot": "image" }, { "from": "shots", "by": "{item.refs.endFromEnd}", "slot": "endFrame" }, { "from": "shots", "by": "{item.refs.endFromStart}", "slot": "startFrame" } ] } },
    { "id": "genMotion", "type": "video", "over": "shots", "out": "motion", "model": "{values.videoModel}", "aspectRatio": "{values.aspect}", "durationSeconds": "{item.duration}", "prompt": "{item.videoPrompt}",
      "startFrame": "{item.slots.startFrame}", "endFrame": "{item.slots.endFrame}",
      "refs": { "op": "lookupRefs", "from": "uploads", "by": "{item.refs.vsUp}", "slot": "media", "also": [ { "from": "assets", "by": "{item.refs.vsAsset}", "slot": "image" }, { "from": "shots", "by": "{item.refs.vsStart}", "slot": "startFrame" }, { "from": "shots", "by": "{item.refs.vsEnd}", "slot": "endFrame" }, { "from": "uploads", "by": "{item.refs.veUp}", "slot": "media" }, { "from": "assets", "by": "{item.refs.veAsset}", "slot": "image" }, { "from": "shots", "by": "{item.refs.veStart}", "slot": "startFrame" }, { "from": "shots", "by": "{item.refs.veEnd}", "slot": "endFrame" } ] } },
    { "id": "genImage", "type": "image", "over": "images", "out": "image", "model": "{values.imageModel}", "aspectRatio": "{values.aspect}", "prompt": "{item.prompt}",
      "refs": { "op": "lookupRefs", "from": "uploads", "by": "{item.refs.up}", "slot": "media", "also": [ { "from": "assets", "by": "{item.refs.asset}", "slot": "image" }, { "from": "images", "by": "{item.refs.img}", "slot": "image" } ] } }
  ],
  "stages": [ { "op": "genAsset" }, { "checkpoint": "build" } ],
  "phases": [
    {
      "id": "build", "title": "ออกแบบงาน", "hideTitle": true, "navLabel": "ออกแบบ",
      "form": [
        { "el": "split", "sidebarWidth": 300, "mainClass": "!p-0 !gap-0 min-h-[calc(100vh-56px)]",
          "style": { "background": "rgba(255,255,255,0.015)", "borderRight": "1px solid rgba(255,255,255,0.07)", "padding": "18px 16px", "maxHeight": "none", "top": "0", "minHeight": "calc(100vh - 56px)" },
          "sidebar": [
            { "el": "box", "className": "border border-white/10 rounded-2xl p-3.5 flex flex-col gap-3.5", "card": [
              { "el": "row", "style": { "justifyContent": "space-between", "alignItems": "flex-start" }, "card": [
                { "el": "box", "style": { "flex": "1" }, "card": [
                  { "el": "text", "value": "Video Pipeline", "className": "text-[13px] font-black leading-none", "when": "genMode=video" },
                  { "el": "text", "value": "Image Pipeline", "className": "text-[13px] font-black leading-none", "when": "genMode=image" },
                  { "el": "text", "value": { "op": "concat", "parts": [ { "op": "count", "from": "assets" }, " assets · ", { "op": "count", "from": "images" }, " images · ", { "op": "count", "from": "shots" }, " videos" ] }, "className": "text-[9px] text-white/40 mt-1" }
                ] },
                { "el": "text", "value": { "op": "concat", "parts": [ { "op": "count", "from": "shots" }, " tasks" ] }, "className": "text-[9px] text-white/40" }
              ] },
              { "el": "row", "style": { "alignItems": "center", "gap": "4px" }, "card": [
                { "el": "box", "className": "flex flex-col items-center gap-1.5 flex-1", "card": [
                  { "el": "box", "className": "w-11 h-11 rounded-xl border border-white/10 flex items-center justify-center bg-white/[0.03]", "card": [ { "el": "icon", "icon": "inventory_2", "className": "text-white/50" } ] },
                  { "el": "text", "value": "ASSETS", "className": "text-[8px] font-bold uppercase tracking-[1.5px] text-white/35" },
                  { "el": "text", "value": { "op": "count", "from": "assets" }, "className": "text-[13px] font-black" }
                ] },
                { "el": "box", "className": "h-px w-4 bg-white/12 self-start mt-[17px] shrink-0" },
                { "el": "box", "className": "flex flex-col items-center gap-1.5 flex-1", "card": [
                  { "el": "box", "className": "w-11 h-11 rounded-xl border border-white/10 flex items-center justify-center bg-white/[0.03]", "card": [ { "el": "icon", "icon": "image", "className": "text-white/50" } ] },
                  { "el": "text", "value": "IMAGE", "className": "text-[8px] font-bold uppercase tracking-[1.5px] text-white/35" },
                  { "el": "text", "value": { "op": "count", "from": "shots", "slot": "startFrame" }, "className": "text-[13px] font-black" }
                ] },
                { "el": "box", "className": "h-px w-4 bg-white/12 self-start mt-[17px] shrink-0" },
                { "el": "box", "className": "flex flex-col items-center gap-1.5 flex-1", "card": [
                  { "el": "box", "className": "w-11 h-11 rounded-xl border border-white/10 flex items-center justify-center bg-white/[0.03]", "card": [ { "el": "icon", "icon": "movie", "className": "text-white/50" } ] },
                  { "el": "text", "value": "VIDEO", "className": "text-[8px] font-bold uppercase tracking-[1.5px] text-white/35" },
                  { "el": "text", "value": { "op": "count", "from": "shots", "slot": "motion" }, "className": "text-[13px] font-black" }
                ] }
              ] }
            ] },
            { "el": "text", "value": "OUTPUT CONFIG", "className": "text-[9px] font-black uppercase tracking-[2px] text-white/35 mt-2" },
            { "el": "segmented", "field": "genMode", "variant": "tab", "options": [ { "value": "video", "label": "VIDEO", "icon": "videocam" }, { "value": "image", "label": "IMAGE", "icon": "image" } ] },
            { "el": "segmented", "field": "aspect", "variant": "tab", "options": [ { "value": "9:16", "label": "9:16" }, { "value": "16:9", "label": "16:9" } ] },
            { "el": "dropdown", "field": "imageModel", "label": "IMAGE MODEL", "variant": "pill", "options": { "table": "imageModels" } },
            { "el": "dropdown", "field": "videoModel", "label": "VIDEO MODEL", "variant": "pill", "options": { "table": "videoModels" }, "when": "genMode=video" },
            { "el": "gen-phase", "label": "เริ่มรันงาน", "ops": ["genAsset"], "chain": ["genStart", "genEnd", "genMotion"], "variant": "solid", "icon": "play_arrow", "when": "genMode=video" },
            { "el": "gen-phase", "label": "เริ่มรันงาน", "ops": ["genAsset", "genImage"], "variant": "solid", "icon": "play_arrow", "when": "genMode=image" },
            { "el": "text", "value": "ACTIVITY STREAM", "className": "text-[9px] font-black uppercase tracking-[2px] text-white/35 mt-2" },
            { "el": "custom", "fn": "flowLog" },
            { "el": "divider" },
            { "el": "row", "style": { "justifyContent": "space-between", "alignItems": "center" }, "card": [
              { "el": "text", "value": "● READY", "className": "text-[9px] font-bold uppercase tracking-widest text-green-400/70" },
              { "el": "text", "value": "flow v0.4", "className": "text-[9px] text-white/25" }
            ] }
          ],
          "main": [
            { "el": "box", "className": "h-14 border-b border-white/5 flex items-center justify-between px-8 bg-[#0a0a0a] shrink-0 w-full", "card": [
              { "el": "text", "value": "Visual Job Designer", "className": "font-black !text-[11px] uppercase tracking-widest !text-white/40 leading-none" },
              { "el": "box", "className": "flex items-center gap-3", "card": [
                { "el": "load-button", "label": "Import", "icon": "upload_file", "className": "!h-8 !border-white/15 hover:!bg-white/5 !bg-transparent" },
                { "el": "segmented", "field": "viewMode", "variant": "tab", "options": [ { "value": "visual", "label": "Visual", "icon": "visibility" }, { "value": "json", "label": "JSON", "icon": "data_object" } ] }
              ] }
            ] },
            { "el": "box", "when": "viewMode=json", "className": "p-10 w-full bg-[#080808] flex-1", "card": [
              { "el": "box", "className": "max-w-[840px] mx-auto w-full", "card": [
                { "el": "box", "className": "bg-white/[0.03] border border-white/5 rounded-[32px] overflow-hidden flex flex-col shadow-2xl", "card": [
                  { "el": "box", "className": "h-14 px-8 border-b border-white/5 bg-white/[0.02] flex items-center gap-3", "card": [
                    { "el": "icon", "icon": "data_object", "className": "text-white/20", "textSize": "text-[18px]" },
                    { "el": "text", "value": "Job JSON", "className": "!text-[10px] font-black uppercase tracking-[3px] !text-white/30" }
                  ] },
                  { "el": "box", "className": "p-10 bg-[#0a0a0a]/50", "card": [ { "el": "custom", "fn": "flowJson" } ] }
                ] }
              ] }
            ] },
            { "el": "box", "when": "viewMode=visual", "className": "p-10 w-full", "card": [
              { "el": "box", "className": "max-w-[800px] mx-auto w-full flex flex-col gap-12 pb-20", "card": [

                { "el": "box", "className": "flex flex-col gap-6", "card": [
                  { "el": "box", "className": "flex items-center justify-between border-b border-white/5 pb-3", "card": [
                    { "el": "text", "value": "Uploads", "className": "!text-[13px] font-black uppercase tracking-[3px] !text-white/30" },
                    { "el": "add-button", "coll": "uploads", "icon": "add", "iconOnly": true, "variant": "ghost", "size": "lg", "className": "!w-10 !h-10 !p-0 !rounded-xl !bg-white/5 hover:!bg-white !text-white hover:!text-black justify-center transition-all" }
                  ] },
                  { "el": "box", "className": "flex flex-col gap-6", "card": [
                    { "el": "box", "when": { "op": "eq", "a": { "op": "count", "from": "uploads" }, "b": 0 }, "className": "h-24 border border-dashed border-white/5 rounded-[24px] flex items-center justify-center bg-white/[0.01]", "card": [
                      { "el": "text", "value": "No Inputs Defined", "className": "!text-[10px] !text-white/10 font-bold uppercase tracking-widest" }
                    ] },
                    { "el": "repeat", "coll": "uploads", "card": [
                      { "el": "box", "className": "group/ec relative bg-white/[0.03] border border-white/5 rounded-[24px] p-6 flex flex-col gap-6 hover:border-white/10 transition-colors", "card": [
                        { "el": "delete-button", "iconOnly": true, "variant": "ghost", "className": "!absolute !top-4 !right-4 !w-8 !h-8 !p-0 !rounded-full !bg-white/5 hover:!bg-red-500/20 !text-white/20 hover:!text-red-400 justify-center opacity-0 group-hover/ec:opacity-100 transition-all z-10" },
                        { "el": "box", "className": "flex items-center gap-2", "card": [
                          { "el": "text", "value": "ID:", "className": "!text-[10px] !text-white/40 uppercase font-black" },
                          { "el": "box", "className": "w-[140px]", "card": [
                            { "el": "text", "value": "{item.id}", "className": "!bg-white/5 border !border-white/10 !rounded-xl !px-3 h-8 flex items-center !text-[11px] font-bold !text-white/80 w-full" }
                          ] }
                        ] },
                        { "el": "box", "className": "flex gap-6 items-start", "card": [
                          { "el": "box", "className": "w-[140px] shrink-0 flex flex-col gap-2", "card": [
                            { "el": "text", "value": "Asset Source", "className": "!text-[11px] font-black !text-white/40 tracking-[1px] uppercase px-1" },
                            { "el": "box", "when": "item.slots.media!=", "className": "relative w-full", "card": [
                              { "el": "media-slot", "src": "{item.slots.media}", "aspect": "1:1", "className": "!rounded-2xl !border-2 !border-white/10 !bg-black/40" },
                              { "el": "button", "action": "hook", "fn": "clearSlot", "to": "media", "iconOnly": true, "icon": "close", "variant": "ghost", "size": "sm", "className": "!absolute !top-1.5 !right-1.5 !w-6 !h-6 !p-0 !rounded-full !bg-black/60 !text-white/70 hover:!text-white hover:!bg-red-500/60 justify-center z-10 opacity-0 group-hover/ec:opacity-100 transition-all" }
                            ] },
                            { "el": "box", "when": "item.slots.media=", "className": "w-full aspect-square rounded-2xl border-2 border-dashed border-white/5 bg-black/40 overflow-hidden", "card": [
                              { "el": "box", "className": "flex flex-col gap-2 p-2 w-full h-full", "card": [
                                { "el": "upload", "into": "{item.slots.media}", "label": "", "placeholder": "อัพโหลด", "icon": "upload", "accept": "image/*,video/mp4", "className": "flex-1 flex-col !gap-1 !rounded-xl !bg-white !text-black !border-0 !text-[9px] font-black uppercase hover:!bg-gray-200 transition-colors" },
                                { "el": "pick-button", "into": "{item.slots.media}", "filter": "image", "label": "เลือกภาพ", "icon": "photo_library", "variant": "ghost", "className": "flex-1 flex-col !h-auto !px-0 !gap-1 !rounded-xl !bg-white/10 !text-white !text-[9px] font-black uppercase hover:!bg-white/20 justify-center transition-colors" }
                              ] }
                            ] }
                          ] },
                          { "el": "box", "className": "flex-1 flex flex-col gap-4", "card": [
                            { "el": "text", "value": "Status Information", "className": "!text-[11px] font-black !text-white/40 tracking-[1px] uppercase px-1" },
                            { "el": "use", "component": "alertWarn", "when": "item.slots.media=", "params": { "title": "ต้องอัพโหลดรูป", "msg": "Please select a media file to activate this reference." } },
                            { "el": "box", "when": "item.slots.media!=", "className": "flex-1 flex flex-col gap-3 p-4 rounded-2xl bg-green-500/5 border border-green-500/20", "card": [
                              { "el": "box", "className": "flex items-center gap-3", "card": [
                                { "el": "icon", "icon": "check_circle", "className": "text-green-400", "textSize": "text-[24px]" },
                                { "el": "box", "className": "flex flex-col", "card": [
                                  { "el": "text", "value": "Asset Active", "className": "!text-[11px] font-black !text-green-400 uppercase tracking-widest" },
                                  { "el": "text", "value": "{item.mediaName}", "className": "!text-[10px] !text-white/40 truncate max-w-[200px]" }
                                ] }
                              ] },
                              { "el": "box", "className": "h-px bg-white/5 w-full" },
                              { "el": "box", "className": "flex items-center justify-between", "card": [
                                { "el": "text", "value": "Media Source", "className": "!text-[9px] !text-white/20 font-black uppercase tracking-widest" },
                                { "el": "text", "value": "อัพโหลด / คลัง Flow", "className": "!text-[9px] !text-white/40" }
                              ] }
                            ] }
                          ] }
                        ] }
                      ] }
                    ] }
                  ] }
                ] },

                { "el": "box", "className": "flex flex-col gap-6", "card": [
                  { "el": "box", "className": "flex items-center justify-between border-b border-white/5 pb-3", "card": [
                    { "el": "text", "value": "Assets", "className": "!text-[13px] font-black uppercase tracking-[3px] !text-white/30" },
                    { "el": "add-button", "coll": "assets", "icon": "add", "iconOnly": true, "variant": "ghost", "size": "lg", "className": "!w-10 !h-10 !p-0 !rounded-xl !bg-white/5 hover:!bg-white !text-white hover:!text-black justify-center transition-all" }
                  ] },
                  { "el": "box", "className": "flex flex-col gap-6", "card": [
                    { "el": "box", "when": { "op": "eq", "a": { "op": "count", "from": "assets" }, "b": 0 }, "className": "h-24 border border-dashed border-white/5 rounded-[24px] flex items-center justify-center bg-white/[0.01]", "card": [
                      { "el": "text", "value": "No Master Assets", "className": "!text-[10px] !text-white/10 font-bold uppercase tracking-widest" }
                    ] },
                    { "el": "repeat", "coll": "assets", "card": [
                      { "el": "box", "className": "group/ec relative bg-white/[0.03] border border-white/5 rounded-2xl p-5 flex flex-col gap-5 hover:border-white/10 transition-colors", "card": [
                        { "el": "box", "className": "flex items-center justify-between", "card": [
                          { "el": "box", "className": "flex items-center gap-2", "card": [
                            { "el": "text", "value": "ID:", "className": "!text-[10px] !text-white/40 uppercase font-black" },
                            { "el": "box", "className": "w-[120px]", "card": [
                              { "el": "text", "value": "{item.id}", "className": "!bg-white/5 border !border-white/10 !rounded-xl !px-3 h-8 flex items-center !text-[11px] font-bold !text-white/80 w-full" }
                            ] }
                          ] },
                          { "el": "delete-button", "iconOnly": true, "variant": "ghost", "className": "!p-0 !h-auto !rounded-none !bg-transparent hover:!bg-transparent !text-white/10 hover:!text-red-400 opacity-0 group-hover/ec:opacity-100 transition-colors" }
                        ] },
                        { "el": "box", "className": "flex flex-col gap-2", "card": [
                          { "el": "box", "className": "flex items-center justify-between px-1", "card": [
                            { "el": "text", "value": "Prompt:", "className": "!text-[11px] font-black !text-white/40 tracking-[1px] uppercase" },
                            { "el": "ai-fill-button", "field": "prompt", "prompt": "ปรับ prompt สร้างภาพให้ละเอียดสวยขึ้น (ภาษาอังกฤษ): ", "label": "AI Fix Prompt", "icon": "magic_button", "variant": "ghost", "disabledWhen": "item.prompt=", "className": "!h-auto !p-0 !gap-1.5 !rounded-none !text-[10px] font-black uppercase tracking-widest !text-white/40 hover:!text-orange-400 hover:!bg-transparent transition-all" }
                          ] },
                          { "el": "textarea", "field": "prompt", "className": "!bg-black/60 !border-white/10 !rounded-2xl !p-5 !min-h-[140px] !text-[13px] !text-white/90 leading-relaxed font-medium focus:!border-white/30 focus:!bg-black/80" }
                        ] },
                        { "el": "box", "className": "flex flex-col gap-2", "card": [
